default_platform(:ios)

platform :ios do
  before_all do
    setup_ci if is_ci
  end

  def asc_api_key
    app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_CONTENT_BASE64"),
      is_key_content_base64: true
    )
  end

  lane :tests do
    run_tests(
      project: "TravelAssist.xcodeproj",
      scheme: "TravelAssist",
      device: "iPhone 15",
      clean: true
    )
  end

  lane :beta do
    api_key = asc_api_key
    match(
      type: "appstore",
      readonly: true,
      git_url: ENV.fetch("MATCH_GIT_URL"),
      git_basic_authorization: ENV["MATCH_GIT_BASIC_AUTHORIZATION"]
    )
    build_app(
      project: "TravelAssist.xcodeproj",
      scheme: "TravelAssist",
      export_method: "app-store"
    )
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  lane :release do
    api_key = asc_api_key
    match(
      type: "appstore",
      readonly: true,
      git_url: ENV.fetch("MATCH_GIT_URL"),
      git_basic_authorization: ENV["MATCH_GIT_BASIC_AUTHORIZATION"]
    )
    build_app(
      project: "TravelAssist.xcodeproj",
      scheme: "TravelAssist",
      export_method: "app-store"
    )
    upload_to_app_store(
      api_key: api_key,
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false
    )
  end
end
